/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #F5F5F5;
}

.container {
  padding: 30rpx;
}

/* 通用按钮 */
.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  text-align: center;
  border: none;
}

.btn-primary[disabled] {
  background-color: #A0C4E8;
}
