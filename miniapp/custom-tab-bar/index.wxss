.tabbar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(7, 193, 96, 0.1);
  border-top: 2rpx solid #e8f8ee;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tabbar-text {
  font-size: 24rpx;
  color: #9ab89a;
}

.tabbar-item.active .tabbar-text {
  color: #07c160;
  font-weight: 600;
}
