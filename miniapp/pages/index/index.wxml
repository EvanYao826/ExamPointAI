<view class="index-page">
  <!-- 顶部：科目选择 -->
  <view class="header" bindtap="toggleSubjectPicker">
    <text class="current-subject">当前科目：{{currentSubject.name || '请选择'}} {{showPicker ? '▲' : '▼'}}</text>
  </view>

  <!-- 科目下拉列表 -->
  <view class="subject-picker" wx:if="{{showPicker}}">
    <view class="picker-mask" bindtap="closePicker"></view>
    <view class="picker-list">
      <view
        class="picker-item {{item.id === currentSubject.id ? 'active' : ''}}"
        wx:for="{{subjects}}"
        wx:key="id"
        bindtap="selectSubject"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <text>{{item.name}}</text>
        <text wx:if="{{item.id === currentSubject.id}}" class="check">✓</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="entry-grid">
    <view class="entry-item entry-large" hover-class="entry-hover" bindtap="goToPublicBank">
      <view class="entry-icon-wrap entry-icon-green">
        <text class="entry-icon">📚</text>
      </view>
      <text class="entry-label">公共题库</text>
      <text class="entry-desc">海量题库等你刷</text>
    </view>
    <view class="entry-item entry-large" hover-class="entry-hover" bindtap="goToMyBank">
      <view class="entry-icon-wrap entry-icon-blue">
        <text class="entry-icon">📖</text>
      </view>
      <text class="entry-label">我的题库</text>
      <text class="entry-desc">个性化题库管理</text>
    </view>
    <view class="entry-item entry-small" hover-class="entry-hover" bindtap="goToWrong">
      <view class="entry-icon-wrap-sm entry-icon-teal">
        <text class="entry-icon-sm">📝</text>
      </view>
      <text class="entry-label">错题本</text>
    </view>
    <view class="entry-item entry-small" hover-class="entry-hover" bindtap="goToUpload">
      <view class="entry-icon-wrap-sm entry-icon-purple">
        <text class="entry-icon-sm">📤</text>
      </view>
      <text class="entry-label">添加题库</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-num">{{totalCount}}</text>
      <text class="stats-label">总刷题</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{totalAccuracy}}%</text>
      <text class="stats-label">正确率</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{continueDays}}</text>
      <text class="stats-label">连续天数</text>
    </view>
  </view>

  <!-- 排行榜 -->
  <view class="ranking-section">
    <view class="ranking-header">
      <text class="ranking-title">排行榜</text>
      <view class="ranking-tabs">
        <text class="tab {{rankingTab === 'daily' ? 'active' : ''}}" bindtap="switchTab" data-tab="daily">今日</text>
        <text class="tab {{rankingTab === 'weekly' ? 'active' : ''}}" bindtap="switchTab" data-tab="weekly">本周</text>
      </view>
    </view>

    <view class="ranking-list">
      <view class="ranking-item" wx:for="{{rankingList}}" wx:key="rank">
        <text class="rank-badge">{{item.rank <= 3 ? medals[item.rank - 1] : item.rank}}</text>
        <text class="rank-name">{{item.nickname}}</text>
        <text class="rank-count">{{item.score}}题</text>
      </view>

      <view wx:if="{{rankingList.length > 0}}" class="ranking-divider"></view>

      <view class="ranking-item my-rank" wx:if="{{myCount > 0}}">
        <text class="rank-badge">📍</text>
        <text class="rank-name">我</text>
        <text class="rank-count">{{myCount}}题 (第{{myRank}}名)</text>
      </view>
    </view>
  </view>

  <view class="tabbar-placeholder"></view>
</view>
