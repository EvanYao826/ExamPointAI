.index-page {
  min-height: 100vh;
  background: #e4f0e8;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #07c160 0%, #4A90D9 100%);
  padding: 28rpx 32rpx;
}

.current-subject {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 科目下拉 */
.subject-picker { position: relative; }
.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 99; }
.picker-list {
  position: absolute; top: 0; left: 0; right: 0;
  background: #fff; z-index: 100;
  box-shadow: 0 12rpx 40rpx rgba(7, 193, 96, 0.2);
  border-radius: 0 0 24rpx 24rpx;
  max-height: 600rpx; overflow-y: auto;
}
.picker-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; font-size: 30rpx; color: #1a2e1a;
  border-bottom: 2rpx solid #e4f0e8;
}
.picker-item:last-child { border-bottom: none; }
.picker-item.active { color: #07c160; font-weight: 600; background: #e8f8ee; }
.check { color: #07c160; font-size: 36rpx; font-weight: 700; }

/* 功能入口 */
.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 32rpx;
}

.entry-item {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(7, 193, 96, 0.12);
  border: 2rpx solid #d4e8d8;
}

.entry-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 大按钮 */
.entry-large {
  padding: 48rpx 30rpx 36rpx;
}

.entry-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.entry-icon-green {
  background: linear-gradient(135deg, #07c160, #059a4a);
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.entry-icon-blue {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 217, 0.3);
}

.entry-icon {
  font-size: 52rpx;
}

.entry-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2e1a;
  margin-bottom: 6rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: #9ab89a;
}

/* 小按钮 */
.entry-small {
  padding: 32rpx 30rpx;
  flex-direction: row;
  gap: 20rpx;
}

.entry-icon-wrap-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-icon-teal {
  background: linear-gradient(135deg, #36d1a0, #0ea5e9);
  box-shadow: 0 6rpx 16rpx rgba(54, 209, 160, 0.3);
}

.entry-icon-purple {
  background: linear-gradient(135deg, #4A90D9, #6C5CE7);
  box-shadow: 0 6rpx 16rpx rgba(108, 92, 231, 0.3);
}

.entry-icon-sm {
  font-size: 36rpx;
}

.entry-small .entry-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2e1a;
}

/* 排行榜 */
.ranking-section {
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(7, 193, 96, 0.12);
  border: 2rpx solid #d4e8d8;
}

.ranking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.ranking-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2e1a;
}

.ranking-tabs {
  display: flex;
  gap: 12rpx;
}

.tab {
  font-size: 26rpx;
  color: #9ab89a;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: #e4f0e8;
}

.tab.active {
  color: #fff;
  background: linear-gradient(135deg, #07c160 0%, #4A90D9 100%);
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
}

.rank-badge { width: 60rpx; font-size: 32rpx; text-align: center; }
.rank-name { flex: 1; font-size: 28rpx; color: #1a2e1a; margin-left: 16rpx; }
.rank-count { font-size: 26rpx; color: #5a7a5a; }

.ranking-divider { height: 2rpx; background: #d4e8d8; margin: 4rpx 0; }

.my-rank {
  background: linear-gradient(135deg, #e8f8ee, #eaf2fb);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  margin: 4rpx -8rpx;
}

.tabbar-placeholder { height: 120rpx; }
