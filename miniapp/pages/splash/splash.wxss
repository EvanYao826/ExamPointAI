/* 启动页 */
.splash-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.logo-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 绿色加载圈 */
.loading-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #e8e8e8;
  border-top-color: #07c160;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.logo {
  width: 120rpx;
  height: 120rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 40rpx;
  letter-spacing: 8rpx;
}
