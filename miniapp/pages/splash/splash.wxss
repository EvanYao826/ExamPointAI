/* 启动页 */
.splash-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #e8f8ee 0%, #eaf2fb 50%, #f0f7f2 100%);
}

.logo-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #d4e8d8;
  border-top-color: #07c160;
  border-right-color: #4A90D9;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.logo {
  width: 120rpx;
  height: 120rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a2e1a;
  margin-top: 40rpx;
  letter-spacing: 12rpx;
}
