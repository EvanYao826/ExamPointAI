<view class="upload-page">
  <!-- 当前科目提示 -->
  <view class="subject-tip">
    <text class="tip-label">当前科目：</text>
    <text class="tip-value">{{currentSubject || '未选择'}}</text>
    <text class="tip-change" bindtap="changeSubject">切换 ›</text>
  </view>

  <!-- 格式说明 -->
  <view class="format-tip">
    <text class="tip-title">📄 支持格式</text>
    <text class="tip-item">• Word 文档（.docx）</text>
    <text class="tip-item">• PDF 文档（.pdf）</text>
    <text class="tip-item">• 文件大小不超过 20MB</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab {{tab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部题库</view>
    <view class="tab {{tab === 'done' ? 'active' : ''}}" bindtap="switchTab" data-tab="done">成功上传</view>
  </view>

  <!-- 题库列表 -->
  <view class="task-list">
    <view class="task-card {{item.pinned ? 'pinned' : ''}}" wx:for="{{tasks}}" wx:key="id">
      <view class="task-top">
        <view class="task-name-wrap">
          <text class="pin-icon" wx:if="{{item.pinned}}">📌</text>
          <text class="task-name">{{item.bank_name || '未知题库'}}</text>
        </view>
        <view class="task-right">
          <view class="status-badge status-{{item.status}}">
            {{item.status === 0 ? '等待解析' : item.status === 1 ? '解析中...' : item.status === 2 ? '解析成功' : '解析失败'}}
          </view>
          <view class="menu-btn" catchtap="toggleMenu" data-index="{{index}}">⋯</view>
        </view>
      </view>

      <!-- 菜单弹窗 -->
      <view class="menu-popup" wx:if="{{menuIndex === index}}" catchtap="noop">
        <view class="menu-item" catchtap="onRename" data-id="{{item.id}}" data-name="{{item.bank_name}}">📝 重命名</view>
        <view class="menu-item" catchtap="onPinTop" data-id="{{item.id}}">
          {{item.pinned ? '📌 取消置顶' : '📌 置顶'}}
        </view>
        <view class="menu-item menu-danger" catchtap="onDelete" data-id="{{item.id}}">🗑️ 删除</view>
      </view>

      <view class="task-bottom">
        <text class="task-info" wx:if="{{item.status === 2}}">
          共解析出 {{item.success_count}} 题{{item.fail_count > 0 ? '，' + item.fail_count + ' 题解析失败' : ''}}
        </text>
        <text class="task-info task-error" wx:elif="{{item.status === 3}}">
          {{item.error_msg || '解析失败，请检查文档格式'}}
        </text>
        <text class="task-info task-parsing" wx:elif="{{item.status === 1}}">
          正在解析中，请稍候...
        </text>
        <text class="task-info" wx:elif="{{item.status === 0}}">
          等待解析
        </text>
        <text class="task-time">{{item.create_time}}</text>
      </view>
      <view class="task-action" wx:if="{{item.status === 2 && item.success_count > 0}}" bindtap="goToBank" data-id="{{item.bank_id}}">
        <text class="action-text">开始刷题 →</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{tasks.length === 0 && !loading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{tab === 'done' ? '暂无解析成功的题库' : '暂无题库，点击下方按钮上传'}}</text>
    </view>
  </view>

  <!-- 遮罩层 -->
  <view class="mask" wx:if="{{menuIndex >= 0}}" catchtap="closeMenu"></view>

  <!-- 上传按钮 -->
  <view class="btn-upload" hover-class="btn-upload-hover" bindtap="onUpload">
    <text class="btn-upload-icon">+</text>
    <text class="btn-upload-text">上传题库</text>
  </view>
</view>
