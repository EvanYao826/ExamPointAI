.upload-page {
  min-height: 100vh;
  background: #e4f0e8;
  padding-bottom: 160rpx;
}

/* 当前科目提示 */
.subject-tip {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: #e8f8ee;
  border-radius: 12rpx;
  border: 2rpx solid #07c160;
}

.tip-label {
  font-size: 26rpx;
  color: #6b8f6b;
}

.tip-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #07c160;
  flex: 1;
}

.tip-change {
  font-size: 24rpx;
  color: #07c160;
}

/* 格式说明 */
.format-tip {
  margin: 16rpx 32rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #d4e8d8;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2e1a;
  margin-bottom: 12rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #6b8f6b;
  line-height: 1.8;
}

/* Tab */
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #d4e8d8;
  margin-top: 16rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #9ab89a;
  position: relative;
}

.tab.active {
  color: #07c160;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 6rpx;
  background: linear-gradient(135deg, #07c160, #4A90D9);
  border-radius: 3rpx;
}

/* 任务列表 */
.task-list {
  padding: 24rpx 32rpx;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #d4e8d8;
  position: relative;
}

.task-card.pinned {
  border-color: #07c160;
  background: #fafffe;
}

.task-name-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 12rpx;
}

.pin-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.task-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.task-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2e1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 菜单按钮 */
.menu-btn {
  font-size: 32rpx;
  color: #9ab89a;
  padding: 0 8rpx;
  letter-spacing: 2rpx;
}

/* 菜单弹窗 */
.menu-popup {
  position: absolute;
  top: 80rpx;
  right: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 200;
  overflow: hidden;
  min-width: 200rpx;
}

.menu-item {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #1a2e1a;
  border-bottom: 2rpx solid #f0f7f2;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f5faf7;
}

.menu-danger {
  color: #fa5151;
}

/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

/* 状态标签 */
.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-0 {
  background: #eaf2fb;
  color: #576b95;
}

.status-1 {
  background: #fff7e6;
  color: #ff9900;
}

.status-2 {
  background: #e8f8ee;
  color: #07c160;
}

.status-3 {
  background: #fff0f0;
  color: #fa5151;
}

.task-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-info {
  font-size: 24rpx;
  color: #9ab89a;
}

.task-error {
  color: #fa5151;
}

.task-parsing {
  color: #ff9900;
}

.task-time {
  font-size: 22rpx;
  color: #b2b2b2;
}

.task-action {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f7f2;
}

.action-text {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ab89a;
}

/* 上传按钮 */
.btn-upload {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #4A90D9);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

.btn-upload-hover {
  opacity: 0.8;
}

.btn-upload-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

.btn-upload-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}
