<!-- 登录页 -->
<view class="login-page">
  <!-- 顶部品牌区 -->
  <view class="brand">
    <image class="brand-logo" src="/assets/icons/logo.png" mode="aspectFit"></image>
    <text class="brand-name">考点通</text>
    <text class="brand-slogan">大学生自己的刷题神器</text>
  </view>

  <!-- 登录表单 -->
  <view class="form">
    <!-- 手机号输入 -->
    <view class="input-wrap">
      <view class="input-row">
        <text class="input-prefix">+86</text>
        <view class="input-divider"></view>
        <input
          class="input-field"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
          focus="{{true}}"
        />
      </view>
    </view>

    <!-- 验证码输入 -->
    <view class="input-wrap">
      <view class="input-row">
        <input
          class="input-field"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="placeholder"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view
          class="btn-code {{countdown > 0 ? 'btn-code-disabled' : ''}}"
          bindtap="onSendCode"
        >
          {{countdown > 0 ? countdown + 's 后重发' : '获取验证码'}}
        </view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <button
      class="btn-login {{phone.length === 11 && code.length === 6 ? 'btn-login-active' : ''}}"
      disabled="{{phone.length !== 11 || code.length !== 6}}"
      bindtap="onLogin"
    >
      登录
    </button>

    <!-- 其他登录方式 -->
    <view class="other-login">
      <view class="divider-line">
        <view class="line"></view>
        <text class="divider-text">其他登录方式</text>
        <view class="line"></view>
      </view>
      <view class="wx-login" bindtap="onWxLogin">
        <view class="wx-icon-wrap">
          <text class="wx-icon">💬</text>
        </view>
        <text class="wx-text">微信快捷登录</text>
      </view>
    </view>
  </view>

  <!-- 底部协议 -->
  <view class="agreement">
    <text class="agreement-text">登录即表示同意</text>
    <text class="agreement-link">《用户协议》</text>
    <text class="agreement-text">和</text>
    <text class="agreement-link">《隐私政策》</text>
  </view>
</view>
