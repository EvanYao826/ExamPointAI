<view class="login-page">
  <!-- Logo -->
  <view class="logo-section">
    <text class="logo-title">考 点 通</text>
    <text class="logo-subtitle">ExamPoint AI</text>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <!-- 手机号 -->
    <view class="input-group">
      <text class="input-icon">📱</text>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 验证码 -->
    <view class="input-group code-group">
      <text class="input-icon">🔑</text>
      <input
        class="input-field code-input"
        type="number"
        maxlength="6"
        placeholder="验证码"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <button
        class="btn-send-code"
        disabled="{{countdown > 0}}"
        bindtap="onSendCode"
      >
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </button>
    </view>

    <!-- 登录按钮 -->
    <button
      class="btn-login"
      disabled="{{!phone || !code}}"
      bindtap="onLogin"
    >
      登 录
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="footer">
    <text class="footer-text">登录即表示同意《用户协议》</text>
  </view>
</view>
