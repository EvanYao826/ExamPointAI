/* 登录页 */
.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  background: #fff;
}

/* 品牌区 */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 180rpx;
}

.brand-logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 8rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 表单区 */
.form {
  width: 100%;
  margin-top: 100rpx;
}

/* 输入框容器 */
.input-wrap {
  background: #f7f8fa;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
}

.input-row {
  display: flex;
  align-items: center;
  height: 104rpx;
}

.input-prefix {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 24rpx;
}

.input-divider {
  width: 2rpx;
  height: 36rpx;
  background: #e0e0e0;
  margin-right: 24rpx;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #333;
}

.placeholder {
  color: #c0c0c0;
  font-size: 30rpx;
}

/* 获取验证码按钮 */
.btn-code {
  font-size: 28rpx;
  color: #4A90D9;
  white-space: nowrap;
  padding-left: 24rpx;
  border-left: 2rpx solid #e0e0e0;
}

.btn-code-disabled {
  color: #c0c0c0;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #c8d6e5;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-top: 48rpx;
  border: none;
  text-align: center;
}

.btn-login-active {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.btn-login::after {
  border: none;
}

/* 其他登录方式 */
.other-login {
  margin-top: 80rpx;
}

.divider-line {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.line {
  flex: 1;
  height: 2rpx;
  background: #eee;
}

.divider-text {
  font-size: 24rpx;
  color: #c0c0c0;
  padding: 0 24rpx;
}

.wx-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-icon {
  font-size: 48rpx;
}

.wx-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 底部协议 */
.agreement {
  position: fixed;
  bottom: 80rpx;
  display: flex;
  align-items: center;
}

.agreement-text {
  font-size: 22rpx;
  color: #c0c0c0;
}

.agreement-link {
  font-size: 22rpx;
  color: #4A90D9;
}
