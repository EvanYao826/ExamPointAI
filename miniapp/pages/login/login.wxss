.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  background: linear-gradient(180deg, #4A90D9 0%, #F5F5F5 50%);
}

/* Logo */
.logo-section {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-title {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 16rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

/* 表单 */
.form-section {
  width: 100%;
  margin-top: 100rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
}

.code-group {
  position: relative;
}

.code-input {
  flex: 1;
}

.btn-send-code {
  font-size: 26rpx;
  color: #4A90D9;
  background: transparent;
  border: 2rpx solid #4A90D9;
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  line-height: 1.5;
  min-height: auto;
}

.btn-send-code[disabled] {
  color: #999;
  border-color: #ccc;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 16rpx;
  margin-top: 40rpx;
  border: none;
}

.btn-login[disabled] {
  background: #A0C4E8;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}
