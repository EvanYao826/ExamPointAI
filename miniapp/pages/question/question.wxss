.question-page {
  min-height: 100vh;
  background: #e4f0e8;
  padding-bottom: 40rpx;
}

/* 顶部 */
.top-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; padding: 24rpx 32rpx; border-bottom: 2rpx solid #d4e8d8;
}
.bank-name { font-size: 30rpx; font-weight: 600; color: #1a2e1a; }
.progress { font-size: 26rpx; color: #9ab89a; }

/* 加载/空 */
.loading-wrap, .done-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 0;
}
.loading-text { font-size: 28rpx; color: #9ab89a; }
.done-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.done-text { font-size: 32rpx; color: #1a2e1a; font-weight: 600; margin-bottom: 40rpx; }
.btn-back {
  background: linear-gradient(135deg, #07c160, #4A90D9);
  color: #fff; padding: 20rpx 60rpx; border-radius: 40rpx; font-size: 28rpx;
}

/* 题目 */
.question-body { padding: 32rpx; }

.question-meta { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.type-tag {
  font-size: 24rpx; color: #07c160; background: #e8f8ee;
  padding: 6rpx 16rpx; border-radius: 8rpx; font-weight: 600;
}
.difficulty { font-size: 24rpx; color: #ffa502; }

.question-text {
  font-size: 32rpx; color: #1a2e1a; line-height: 1.6; font-weight: 500;
  display: block; margin-bottom: 32rpx;
}

/* 选项 */
.options { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 24rpx; }

/* 多选题提交按钮 */
.btn-submit-multi {
  width: 100%; height: 88rpx; line-height: 88rpx; text-align: center;
  background: linear-gradient(135deg, #07c160, #4A90D9);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 44rpx; margin-bottom: 24rpx;
}

.option-item {
  display: flex; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  border: 2rpx solid #d4e8d8;
}

.option-item.correct { border-color: #07c160; background: #e8f8ee; }
.option-item.wrong { border-color: #fa5151; background: #fff0f0; }
.option-item.multi-selected { border-color: #4A90D9; background: #eaf2fb; }

.option-key {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: #e4f0e8; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 600; color: #5a7a5a; margin-right: 20rpx; flex-shrink: 0;
}
.option-item.correct .option-key { background: #07c160; color: #fff; }
.option-item.wrong .option-key { background: #fa5151; color: #fff; }

.option-content { flex: 1; font-size: 28rpx; color: #1a2e1a; line-height: 1.5; }

.option-mark { font-size: 32rpx; color: #07c160; font-weight: 700; margin-left: 16rpx; }
.wrong-mark { color: #fa5151; }

/* 解析 */
.analysis {
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  margin-bottom: 32rpx; border: 2rpx solid #d4e8d8;
}
.analysis-title { font-size: 28rpx; font-weight: 600; color: #1a2e1a; margin-bottom: 16rpx; display: block; }
.analysis-text { font-size: 26rpx; color: #5a7a5a; line-height: 1.6; }

/* 底部操作 */
.action-bar { display: flex; gap: 16rpx; align-items: center; margin-bottom: 32rpx; }

.btn-nav {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: #fff; color: #5a7a5a; font-size: 28rpx; font-weight: 600;
  border-radius: 44rpx; border: 2rpx solid #d4e8d8;
}
.btn-nav.disabled { opacity: 0.4; }

.btn-next { background: linear-gradient(135deg, #07c160, #4A90D9); color: #fff; border: none; }
.btn-next.disabled { background: #c8d6e5; }

.btn-analysis {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: #e8f8ee; color: #07c160; font-size: 28rpx; font-weight: 600;
  border-radius: 44rpx; border: 2rpx solid #07c160;
}
