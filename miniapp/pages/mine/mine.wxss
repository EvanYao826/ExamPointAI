.mine-page {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
  background: #e4f0e8;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.08);
  border: 2rpx solid #e8f8ee;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 32rpx;
  flex-shrink: 0;
  border: 4rpx solid #e8f8ee;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e8f8ee, #eaf2fb);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #9ab89a;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a2e1a;
}

.phone {
  font-size: 26rpx;
  color: #9ab89a;
  margin-top: 8rpx;
}

.login-hint {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a2e1a;
}

.login-sub {
  font-size: 26rpx;
  color: #9ab89a;
  margin-top: 8rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #07c160 0%, #4A90D9 100%);
  border-radius: 24rpx;
  padding: 40rpx 0;
  margin: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 菜单列表 */
.menu-group {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.08);
  border: 2rpx solid #e8f8ee;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 2rpx solid #f0f7f2;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 30rpx;
  color: #1a2e1a;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d4e8d8;
}

.tabbar-placeholder {
  height: 120rpx;
}
