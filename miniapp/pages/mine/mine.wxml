<!-- 我的页面 -->
<view class="mine-page">
  <!-- 用户信息区 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/logo.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="phone">{{userInfo.phone || '点击登录'}}</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.total_count || 0}}</text>
      <text class="stat-label">总刷题</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.accuracy || 0}}%</text>
      <text class="stat-label">正确率</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.continue_days || 0}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goToMyBanks">
      <text class="menu-text">📚 我的题库</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSubjects">
      <text class="menu-text">📝 修改科目</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSchool">
      <text class="menu-text">🏫 修改学校/专业</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
